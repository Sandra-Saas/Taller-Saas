generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id                    String    @id @default(uuid())
  businessName          String
  commercialName        String
  cuit                  String    @unique
  ivaCondition          String
  grossIncome           String?
  address               String?
  city                  String?
  province              String?
  country               String?   @default("Argentina")
  postalCode            String?
  phone                 String?
  email                 String
  logo                  String?
  status                String    @default("active") // active, suspended, cancelled
  planId                String
  subscriptionId        String?
  subscriptionStartDate DateTime?
  subscriptionEndDate   DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  config                Json?

  // Relations
  plan              Plan              @relation(fields: [planId], references: [id])
  subscription      Subscription?     @relation(fields: [subscriptionId], references: [id])
  users             User[]
  roles             Role[]
  permissions       Permission[]
  auditLogs         AuditLog[]
  settings          Setting[]
  // Business models (to be added later)
  // clients           Client[]
  // vehicles          Vehicle[]
  // etc...

  @@map("tenants")
}

model User {
  id           String   @id @default(uuid())
  firstName    String
  lastName     String
  email        String   @unique
  password     String   // Hashed password
  status       String   @default("active") // active, inactive
  tenantId     String
  roleId       String
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role         Role     @relation(fields: [roleId], references: [id])
  auditLogs    AuditLog[]

  @@map("users")
}

model Role {
  id          String       @id @default(uuid())
  name        String
  description String?
  tenantId    String
  isSystem    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       User[]
  permissions Permission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  module      String
  action      String
  resource    String
  tenantId    String
  roleId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role        Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, roleId, module, action, resource])
  @@map("permissions")
}

model Plan {
  id               String   @id @default(uuid())
  name             String
  description      String?
  status           String   @default("active")
  maxUsers         Int
  basePrice        Decimal  @db.Decimal(12, 2)
  ivaPercentage    Decimal  @db.Decimal(5, 2) @default(21.00)
  ivaAmount        Decimal  @db.Decimal(12, 2)
  finalPrice       Decimal  @db.Decimal(12, 2)
  benefits         String[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  tenants          Tenant[]
  subscriptions    Subscription[]

  @@map("plans")
}

model Subscription {
  id             String   @id @default(uuid())
  tenantId       String   @unique
  planId         String
  status         String   @default("active") // active, pending, suspended, cancelled
  startDate      DateTime
  endDate        DateTime?
  autoRenew      Boolean  @default(true)
  paymentMethod  String?
  lastPaymentDate DateTime?
  nextPaymentDate DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  plan           Plan     @relation(fields: [planId], references: [id])
  history        SubscriptionHistory[]

  @@map("subscriptions")
}

model SubscriptionHistory {
  id             String   @id @default(uuid())
  subscriptionId String
  action         String // created, renewed, upgraded, downgraded, suspended, reactivated, cancelled
  oldPlanId      String?
  newPlanId      String?
  notes          String?
  createdAt      DateTime @default(now())

  // Relations
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("subscription_history")
}

model Setting {
  id          String   @id @default(uuid())
  tenantId    String
  key         String
  value       String
  type        String   @default("string")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@map("settings")
}

model AuditLog {
  id          String   @id @default(uuid())
  tenantId    String
  userId      String?
  action      String
  entity      String
  entityId    String?
  oldData     Json?
  newData     Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  // Relations
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

// Super Admin (System-wide)
model SuperAdmin {
  id        String   @id @default(uuid())
  firstName String
  lastName  String
  email     String   @unique
  password  String
  status    String   @default("active")
  lastLoginAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("super_admins")
}
